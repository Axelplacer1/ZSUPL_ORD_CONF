{
    "configurations": [
        {
            "name": "Start variance",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "cwd": "${workspaceFolder}/variance",
            "windows": {
                "runtimeExecutable": "npx.cmd"
            },
            "runtimeArgs": [
                "fiori",
                "run"
            ],
            "args": [
                "--open",
                "test/flpSandbox.html#aucomiesolpoconfirmationvarian-tile"
            ],
            "console": "internalConsole",
