{
    "name": "variance_wf_task",
    "version": "0.0.1",
    "private": true,
    "description": "Action variance",
    "keywords": [
        "ui5",
        "openui5",
        "sapui5"
    ],
    "main": "webapp/index.html",
    "devDependencies": {
        "@sap/ux-ui5-tooling": "^1.18.0",
        "@sapui5/types": "^1.143.0",
        "@types/estree": "1.0.8",
        "@ui5/cli": "^4.0.0",
        "@ui5/linter": "^1.5.0",
        "eslint": "^9.39.2",
        "rimraf": "^6.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.51.0",
        "ui5-task-flatten-library": "3.1.0",
        "ui5-tooling-transpile": "^3"
    },
    "scripts": {
        "start": "fiori run --open \"test/flpSandbox.html?sap-ui-xx-viewCache=false#aucomiesolpoconfirmationvarian-display\"",
        "start-local": "fiori run --config ./ui5-local.yaml --open \"test/flpSandbox.html?sap-ui-xx-viewCache=false#aucomiesolpoconfirmationvarian-display\"",
        "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
        "lint": "eslint ./",
        "ts-typecheck": "tsc --noEmit",
        "prestart": "npm run ts-typecheck",
        "prebuild": "npm run ts-typecheck",
        "deploy": "npm run build && fiori deploy --config ui5-deploy.yaml && rimraf archive.zip",
        "deploy-config": "fiori add deploy-config",
        "start-noflp": "fiori run --open \"index.html?sap-ui-xx-viewCache=false\"",
        "start-variants-management": "fiori run --open \"preview.html?sap-ui-xx-viewCache=false&fiori-tools-rta-mode=true&sap-ui-rta-skip-flex-validation=true#preview-app\"",
        "unit-tests": "fiori run --open 'test/unit/unitTests.qunit.html'",
        "int-tests": "fiori run --open 'test/integration/opaTests.qunit.html'",
        "undeploy": "fiori undeploy --config ui5-deploy.yaml",
        "deploy-test": "npm run build && fiori deploy --config ui5-deploy.yaml --testMode true"
    },
    "sapuxLayer": "CUSTOMER_BASE",
    "ui5": {
        "dependencies": [
            "ui5-task-flatten-library"
        ]
    }
}
