                    "requiresSelection": true
                  },
                  "Resolved": {
                    "id": "idButtonResolved",
                    "text": "{i18n>RESOLVED_BUTTON_TEXT}",
                    "press": "onResolved",
                    "icon": "sap-icon://delete",
                    "requiresSelection": true
                  }
                }
              }
            }
          }
        }
      }
    }
